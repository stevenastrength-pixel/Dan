generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── Projects ─────────────────────────────────────────────────────────────────

model Project {
  id              Int       @id @default(autoincrement())
  name            String
  slug            String    @unique
  description     String    @default("")
  type            String    @default("novel")   // 'novel' | 'campaign'
  sessionNonce    String    @default("")
  contextResetAt  DateTime?
  createdAt       DateTime  @default(now())

  // Campaign-only fields
  levelingMode    String?   // 'xp' | 'milestone'
  partySize       Int?
  minLevel        Int?
  maxLevel        Int?

  chapters          Chapter[]
  characters        Character[]
  worldEntries      WorldEntry[]
  documents         ProjectDocument[]
  polls             Poll[]
  tasks             Task[]
  messages          ProjectMessage[]
  contributors      ProjectContributor[]
  invites           ProjectInvite[]
  partyMembers      PartyMember[]
  characterSheets   CharacterSheet[]
  liveSessions      LiveSession[]
  playRuns          PlayRun[]
  sessions          Session[]
  locations         Location[]
  encounters        Encounter[]
  quests            Quest[]
  randomTables      RandomTable[]
  timelineEvents    TimelineEvent[]
  campaignCreatures CampaignCreature[]
  campaignMagicItems CampaignMagicItem[]
}

model ProjectMessage {
  id           Int      @id @default(autoincrement())
  projectId    Int
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  role         String   // 'user' | 'assistant'
  author       String
  content      String
  imageUrl     String?
  fileName     String?
  isPinned     Boolean  @default(false)
  createdAt    DateTime @default(now())
}

model GlobalMessage {
  id        Int      @id @default(autoincrement())
  role      String   // 'user' | 'assistant'
  author    String
  content   String
  imageUrl  String?
  fileName  String?
  isPinned  Boolean  @default(false)
  createdAt DateTime @default(now())
}

model UserPresence {
  projectId          Int
  username           String
  lastSeen           DateTime @default(now())
  lastReadMessageId  Int?

  @@id([projectId, username])
}

model ProjectContributor {
  projectId Int
  username  String
  joinedAt  DateTime @default(now())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@id([projectId, username])
}

model ProjectInvite {
  token     String   @id
  projectId Int
  createdAt DateTime @default(now())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model ProjectDocument {
  id         Int      @id @default(autoincrement())
  projectId  Int      @default(1)
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  key        String
  title      String
  content    String   @default("")
  isHandout  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([projectId, key])
}

// ─── Chapters ─────────────────────────────────────────────────────────────────

model Chapter {
  id             String   @id @default(cuid())
  projectId      Int      @default(1)
  project        Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title          String
  order          Int      @default(0)
  content        String   @default("")
  synopsis       String   @default("")
  intendedLevel  Int?     // Campaign only: level band entering this part
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  versions ChapterVersion[]
  comments Comment[]
}

model ChapterVersion {
  id        String   @id @default(cuid())
  chapterId String
  chapter   Chapter  @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  content   String
  savedBy   String   @default("Unknown")
  createdAt DateTime @default(now())
}

model Comment {
  id        String   @id @default(cuid())
  chapterId String
  chapter   Chapter  @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  text      String
  author    String   @default("Unknown")
  resolved  Boolean  @default(false)
  createdAt DateTime @default(now())
}

// ─── Characters ───────────────────────────────────────────────────────────────

model Character {
  id          String   @id @default(cuid())
  projectId   Int      @default(1)
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name        String
  role        String   @default("Supporting")
  description String   @default("")
  notes       String   @default("")
  traits      String   @default("[]")
  // Campaign NPC extensions
  knownInfo         String @default("")
  secrets           String @default("")
  voiceNotes        String @default("")
  statBlockRef      String @default("")
  factionId         String?
  currentLocationId String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─── World Building ───────────────────────────────────────────────────────────

model WorldEntry {
  id          String   @id @default(cuid())
  projectId   Int      @default(1)
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name        String
  type        String   @default("Location")
  description String   @default("")
  notes       String   @default("")
  // Faction extensions (campaign mode)
  factionGoals     String @default("")
  factionMethods   String @default("")
  factionRelations String @default("[]")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─── Users ────────────────────────────────────────────────────────────────────

model User {
  id                 Int      @id @default(autoincrement())
  username           String   @unique
  passwordHash       String
  role               String   @default("contributor") // "admin" | "contributor"
  openClawSessionKey String   @unique @default(cuid())
  createdAt          DateTime @default(now())
}

// ─── Settings (global, not per-project) ──────────────────────────────────────

model Settings {
  id              Int      @id @default(1)
  inviteCode      String   @default("")
  styleGuide      String   @default("")
  aiProvider      String   @default("anthropic")
  aiModel         String   @default("")
  aiApiKey        String   @default("")
  openClawBaseUrl String   @default("")
  openClawApiKey  String   @default("")
  openClawAgentId String   @default("")
  contextFiles          String    @default("[]") // JSON array of file paths injected into agent system prompt
  globalSessionNonce    String    @default("")
  globalContextResetAt  DateTime?
  updatedAt             DateTime  @updatedAt
}

// ─── Polls ────────────────────────────────────────────────────────────────────

model Poll {
  id        Int      @id @default(autoincrement())
  projectId Int      @default(1)
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  question  String
  options   String   @default("[]")
  createdAt DateTime @default(now())
  createdBy String
  status    String   @default("OPEN")
  votes     Vote[]
}

model Vote {
  id        Int      @id @default(autoincrement())
  pollId    Int
  poll      Poll     @relation(fields: [pollId], references: [id], onDelete: Cascade)
  voterName String
  optionIdx Int
  createdAt DateTime @default(now())

  @@unique([pollId, voterName])
}

// ─── Tasks ────────────────────────────────────────────────────────────────────

model Task {
  id          Int      @id @default(autoincrement())
  projectId   Int
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignedTo  String
  title       String
  description String   @default("")
  status      String   @default("TODO")  // "TODO" | "IN_PROGRESS" | "DONE"
  createdBy   String   @default("Daneel")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─── SRD Reference Data (read-only, seeded at startup) ───────────────────────

model SrdCreature {
  id                   Int     @id @default(autoincrement())
  name                 String
  size                 String  @default("")
  creatureType         String  @default("")
  alignment            String  @default("")
  CR                   String  @default("0")
  xpValue              Int     @default(0)
  AC                   Int     @default(10)
  acType               String  @default("")
  HPDice               String  @default("")
  HPAverage            Int     @default(1)
  speed                String  @default("{}")
  STR                  Int     @default(10)
  DEX                  Int     @default(10)
  CON                  Int     @default(10)
  INT                  Int     @default(10)
  WIS                  Int     @default(10)
  CHA                  Int     @default(10)
  savingThrows         String  @default("[]")
  skills               String  @default("[]")
  damageResistances    String  @default("[]")
  damageImmunities     String  @default("[]")
  damageVulnerabilities String @default("[]")
  conditionImmunities  String  @default("[]")
  senses               String  @default("")
  languages            String  @default("")
  traits               String  @default("[]")
  actions              String  @default("[]")
  bonusActions         String  @default("[]")
  reactions            String  @default("[]")
  legendaryActions     String  @default("[]")
  lairActions          String  @default("[]")
  isLegendary          Boolean @default(false)
  legendaryResistances Int     @default(0)
  hasLairActions       Boolean @default(false)
}

model SrdSpell {
  id           Int     @id @default(autoincrement())
  name         String
  level        Int     @default(0)
  school       String  @default("")
  castingTime  String  @default("")
  range        String  @default("")
  components   String  @default("")
  duration     String  @default("")
  concentration Boolean @default(false)
  ritual       Boolean @default(false)
  description  String  @default("")
  higherLevels String  @default("")
  classes      String  @default("[]")
}

model SrdMagicItem {
  id                Int     @id @default(autoincrement())
  name              String
  rarity            String  @default("common")
  itemType          String  @default("wondrous")
  requiresAttunement Boolean @default(false)
  description       String  @default("")
}

// ─── Campaign Models (Phase 2 — structure defined now, UI in Phase 2) ─────────

model Session {
  id             Int      @id @default(autoincrement())
  projectId      Int
  project        Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title          String
  summary        String   @default("")
  outline        String   @default("")
  intendedLevel  Int?
  order          Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Location {
  id               Int      @id @default(autoincrement())
  projectId        Int
  project          Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name             String
  locationType     String   @default("dungeon")  // dungeon/town/region/wilderness/building/plane
  description      String   @default("")
  atmosphere       String   @default("")
  parentLocationId Int?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  keyedAreas KeyedArea[]
  encounters Encounter[]
}

model KeyedArea {
  id          Int      @id @default(autoincrement())
  locationId  Int
  location    Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  key         String
  title       String   @default("")
  readAloud   String   @default("")
  dmNotes     String   @default("")
  connections String   @default("[]")
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  encounter Encounter?
}

model Encounter {
  id            Int      @id @default(autoincrement())
  projectId     Int
  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name          String
  encounterType String   @default("combat")  // combat/social/exploration/trap/hazard
  difficulty    String   @default("medium")  // trivial/easy/medium/hard/deadly
  readAloud     String   @default("")
  summary       String   @default("")
  tactics       String   @default("")
  dmNotes       String   @default("")
  locationId    Int?
  location      Location? @relation(fields: [locationId], references: [id])
  keyedAreaId   Int?     @unique
  keyedArea     KeyedArea? @relation(fields: [keyedAreaId], references: [id])
  rewardText    String   @default("")
  status        String   @default("planned")
  isPlaytested  Boolean  @default(false)
  playtestedAt  DateTime?
  // Trap fields
  trapTrigger   String   @default("")
  detectionDC   Int?
  disarmDC      Int?
  trapEffect    String   @default("")
  trapReset     String   @default("")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  creatures EncounterCreature[]
}

model EncounterCreature {
  id                 Int      @id @default(autoincrement())
  encounterId        Int
  encounter          Encounter @relation(fields: [encounterId], references: [id], onDelete: Cascade)
  quantity           Int      @default(1)
  srdCreatureId      Int?
  campaignCreatureId Int?
  notes              String   @default("")
}

model CampaignCreature {
  id                   Int     @id @default(autoincrement())
  projectId            Int
  project              Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name                 String
  size                 String  @default("")
  creatureType         String  @default("")
  alignment            String  @default("")
  CR                   String  @default("0")
  xpValue              Int     @default(0)
  isHomebrew           Boolean @default(true)
  AC                   Int     @default(10)
  acType               String  @default("")
  HPDice               String  @default("")
  HPAverage            Int     @default(1)
  speed                String  @default("{}")
  STR                  Int     @default(10)
  DEX                  Int     @default(10)
  CON                  Int     @default(10)
  INT                  Int     @default(10)
  WIS                  Int     @default(10)
  CHA                  Int     @default(10)
  savingThrows         String  @default("[]")
  skills               String  @default("[]")
  damageResistances    String  @default("[]")
  damageImmunities     String  @default("[]")
  damageVulnerabilities String @default("[]")
  conditionImmunities  String  @default("[]")
  senses               String  @default("")
  languages            String  @default("")
  legendaryResistances Int     @default(0)
  isLegendary          Boolean @default(false)
  hasLairActions       Boolean @default(false)
  traits               String  @default("[]")
  actions              String  @default("[]")
  bonusActions         String  @default("[]")
  reactions            String  @default("[]")
  legendaryActions     String  @default("[]")
  lairActions          String  @default("[]")
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model Quest {
  id               Int      @id @default(autoincrement())
  projectId        Int
  project          Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name             String
  description      String   @default("")
  status           String   @default("active")  // active/resolved/abandoned/unknown-to-party
  questType        String   @default("main")     // main/side/faction/personal
  giverCharacterId String?
  locationId       Int?
  rewardText       String   @default("")
  parentQuestId    Int?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model RandomTable {
  id            Int      @id @default(autoincrement())
  projectId     Int
  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name          String
  tableCategory String   @default("custom")  // encounter/npc-names/rumors/weather/trinkets/custom
  dieSize       String   @default("d20")
  description   String   @default("")
  entries       String   @default("[]")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model TimelineEvent {
  id               Int      @id @default(autoincrement())
  projectId        Int
  project          Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name             String
  inWorldDay       Int      @default(0)
  description      String   @default("")
  triggerCondition String   @default("")
  consequence      String   @default("")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model CampaignMagicItem {
  id                 Int      @id @default(autoincrement())
  projectId          Int
  project            Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name               String
  rarity             String   @default("uncommon")
  itemType           String   @default("wondrous")
  requiresAttunement Boolean  @default(false)
  attunementNotes    String   @default("")
  chargesMax         Int?
  rechargeCondition  String   @default("")
  description        String   @default("")
  properties         String   @default("")
  lore               String   @default("")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

// ─── Play Mode Foundation ──────────────────────────────────────────────────────

// Full D&D 5e character sheet — owned by a user, scoped to a campaign
model CharacterSheet {
  id               String   @id @default(cuid())
  projectId        Int
  project          Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  username         String   // DAN user who owns this sheet

  // Identity
  characterName    String   @default("Unnamed Adventurer")
  className        String   @default("")
  subclass         String   @default("")
  race             String   @default("")
  background       String   @default("")
  alignment        String   @default("")
  level            Int      @default(1)
  xp               Int      @default(0)

  // Ability scores (raw; mods derived)
  STR              Int      @default(10)
  DEX              Int      @default(10)
  CON              Int      @default(10)
  INT              Int      @default(10)
  WIS              Int      @default(10)
  CHA              Int      @default(10)

  // Combat
  maxHP            Int      @default(10)
  currentHP        Int      @default(10)
  tempHP           Int      @default(0)
  AC               Int      @default(10)
  speed            Int      @default(30)
  proficiencyBonus Int      @default(2)
  initiative       Int      @default(0)  // override; normally derived from DEX
  inspiration      Boolean  @default(false)

  // Saving throws — JSON: { STR: bool, DEX: bool, CON: bool, INT: bool, WIS: bool, CHA: bool }
  savingThrowProfs String   @default("{}")

  // Skills — JSON: { Acrobatics: { prof: bool, expertise: bool }, ... }
  skillProfs       String   @default("{}")

  // Death saves
  deathSaveSuccesses Int    @default(0)
  deathSaveFailures  Int    @default(0)

  // Attacks — JSON array: [{ name, attackBonus, damage, damageType, range, notes }]
  attacks          String   @default("[]")

  // Spell slots — JSON: { "1": { max: 4, used: 0 }, "2": { max: 3, used: 0 }, ... }
  spellSlots       String   @default("{}")

  // Spells prepared — JSON array of spell names/SRD ids
  spellsPrepared   String   @default("[]")

  // Inventory — JSON array: [{ name, quantity, weight, notes, isEquipped }]
  inventory        String   @default("[]")

  // Currency — JSON: { cp, sp, ep, gp, pp }
  currency         String   @default("{\"cp\":0,\"sp\":0,\"ep\":0,\"gp\":0,\"pp\":0}")

  // Features & traits — JSON arrays of { name, source, description }
  features         String   @default("[]")

  // Personality
  personalityTraits String  @default("")
  ideals            String  @default("")
  bonds             String  @default("")
  flaws             String  @default("")
  backstory         String  @default("")

  // Active conditions — JSON array of condition strings
  conditions        String  @default("[]")

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  partyMember      PartyMember?
}

// Links a DAN user to a campaign as a party member (separate from authoring contributor)
model PartyMember {
  id               Int      @id @default(autoincrement())
  projectId        Int
  project          Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  username         String
  role             String   @default("player")  // "dm" | "player"
  characterSheetId String?  @unique
  characterSheet   CharacterSheet? @relation(fields: [characterSheetId], references: [id])
  joinedAt         DateTime @default(now())

  @@unique([projectId, username])
}

// ─── DM Live Tools ─────────────────────────────────────────────────────────────

model LiveSession {
  id           Int      @id @default(autoincrement())
  projectId    Int
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  encounterId  Int?
  name         String   @default("Combat")
  roundNumber  Int      @default(1)
  activeIndex  Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  combatants   Combatant[]
}

model Combatant {
  id                 Int     @id @default(autoincrement())
  sessionId          Int
  session            LiveSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  name               String
  type               String  @default("monster")  // "pc" | "monster" | "npc"
  initiative         Int     @default(0)
  sortOrder          Int     @default(0)
  currentHP          Int     @default(10)
  maxHP              Int     @default(10)
  tempHP             Int     @default(0)
  AC                 Int     @default(10)
  speed              Int     @default(30)
  conditions         String  @default("[]")
  spellSlots         String  @default("{}")        // for PCs
  inspiration        Boolean @default(false)
  deathSaveSuccesses Int     @default(0)
  deathSaveFailures  Int     @default(0)
  notes              String  @default("")
  // Source references
  characterSheetId   String?
  srdCreatureId      Int?
  campaignCreatureId Int?
}

// ─── AI Dungeon Crawler ────────────────────────────────────────────────────────

model PlayRun {
  id                 Int      @id @default(autoincrement())
  projectId          Int
  project            Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name               String   @default("Adventure")
  state              String   @default("active")  // "active" | "complete" | "wiped"
  currentLocationId  Int?
  currentKeyedAreaId Int?
  inCombat           Boolean  @default(false)
  roundNumber        Int      @default(1)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  players            PlayRunPlayer[]
  log                PlayRunLog[]
  explored           PlayRunExplored[]
  combatants         PlayRunCombatant[]
}

model PlayRunPlayer {
  id               Int      @id @default(autoincrement())
  runId            Int
  run              PlayRun  @relation(fields: [runId], references: [id], onDelete: Cascade)
  username         String
  characterSheetId String   // snapshot reference
  characterName    String   @default("")
  // Runtime state (mirrors sheet but changes during the run)
  currentHP        Int      @default(10)
  maxHP            Int      @default(10)
  tempHP           Int      @default(0)
  level            Int      @default(1)
  xp               Int      @default(0)
  conditions       String   @default("[]")
  spellSlots       String   @default("{}")
  inventory        String   @default("[]")
  currency         String   @default("{\"cp\":0,\"sp\":0,\"ep\":0,\"gp\":0,\"pp\":0}")
  deathState       String   @default("alive")     // "alive" | "unconscious" | "dead"
  initiative       Int      @default(0)
  isActive         Boolean  @default(true)
  deathSaveSuccesses Int    @default(0)
  deathSaveFailures  Int    @default(0)
}

model PlayRunCombatant {
  id                 Int     @id @default(autoincrement())
  runId              Int
  run                PlayRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  name               String
  type               String  @default("monster")  // "player" | "monster" | "npc"
  initiative         Int     @default(0)
  sortOrder          Int     @default(0)
  currentHP          Int     @default(10)
  maxHP              Int     @default(10)
  tempHP             Int     @default(0)
  AC                 Int     @default(10)
  conditions         String  @default("[]")
  isDefeated         Boolean @default(false)
  // Source refs
  playRunPlayerId    Int?
  srdCreatureId      Int?
  campaignCreatureId Int?
}

model PlayRunLog {
  id          Int      @id @default(autoincrement())
  runId       Int
  run         PlayRun  @relation(fields: [runId], references: [id], onDelete: Cascade)
  type        String   // "narration" | "combat" | "loot" | "skill" | "death" | "dialogue" | "system" | "levelup"
  content     String
  speakerName String   @default("")
  createdAt   DateTime @default(now())
}

model PlayRunExplored {
  id           Int      @id @default(autoincrement())
  runId        Int
  run          PlayRun  @relation(fields: [runId], references: [id], onDelete: Cascade)
  keyedAreaId  Int?
  encounterId  Int?
  clearedAt    DateTime @default(now())

  @@unique([runId, keyedAreaId])
}
